{
  "summary": "Complete design system overhaul for Kafkasder Weekly Planner. Elevate from functional glassmorphism to premium Linear/Things-inspired dark UI with refined tokens, component library, purposeful animations, and full accessibility.",
  "phases": [
    {
      "id": 1,
      "name": "Component Architecture Refactor",
      "description": "Break App.tsx monolith into focused components with clean interfaces",
      "dependencies": []
    },
    {
      "id": 2,
      "name": "Design System Foundation",
      "description": "Token refinement + UI primitive component library",
      "dependencies": [1]
    },
    {
      "id": 3,
      "name": "Visual Polish & Animations",
      "description": "Micro-interactions, transitions, loading states, celebrations",
      "dependencies": [2]
    },
    {
      "id": 4,
      "name": "Mobile UX",
      "description": "Bottom sheets, gestures, FAB, bottom nav, responsive polish",
      "dependencies": [2]
    },
    {
      "id": 5,
      "name": "Accessibility",
      "description": "WCAG 2.1 AA compliance, keyboard nav, focus management, screen readers",
      "dependencies": [2, 3]
    }
  ],
  "tokens": {
    "colors": {
      "surface": {
        "0": "#06060b",
        "1": "#0c0c14",
        "2": "#12121e",
        "3": "#1a1a2e",
        "4": "#22223a"
      },
      "overlay": {
        "subtle": "rgba(255,255,255,0.02)",
        "light": "rgba(255,255,255,0.04)",
        "medium": "rgba(255,255,255,0.08)",
        "strong": "rgba(255,255,255,0.12)",
        "heavy": "rgba(255,255,255,0.16)"
      },
      "border": {
        "subtle": "rgba(255,255,255,0.04)",
        "default": "rgba(255,255,255,0.06)",
        "medium": "rgba(255,255,255,0.08)",
        "strong": "rgba(255,255,255,0.12)",
        "focus": "rgba(99,102,241,0.4)"
      },
      "accent": {
        "DEFAULT": "#6366f1",
        "light": "#818cf8",
        "dark": "#4f46e5",
        "subtle": "rgba(99,102,241,0.08)",
        "glow": "rgba(99,102,241,0.15)"
      },
      "semantic": {
        "success": "#34d399",
        "successSubtle": "rgba(52,211,153,0.1)",
        "warning": "#fbbf24",
        "warningSubtle": "rgba(251,191,36,0.1)",
        "danger": "#f87171",
        "dangerSubtle": "rgba(248,113,113,0.1)",
        "info": "#60a5fa",
        "infoSubtle": "rgba(96,165,250,0.1)"
      }
    },
    "typography": {
      "fontFamily": {
        "sans": "Inter, ui-sans-serif, system-ui, sans-serif",
        "display": "Space Grotesk, Inter, ui-sans-serif, system-ui, sans-serif",
        "mono": "JetBrains Mono, ui-monospace, monospace"
      },
      "scale": {
        "caption": { "size": "10px", "lineHeight": "14px", "weight": 500, "letterSpacing": "0.02em" },
        "label": { "size": "11px", "lineHeight": "16px", "weight": 600, "letterSpacing": "0.08em", "textTransform": "uppercase" },
        "body-sm": { "size": "12px", "lineHeight": "18px", "weight": 400 },
        "body": { "size": "14px", "lineHeight": "22px", "weight": 400 },
        "body-medium": { "size": "14px", "lineHeight": "22px", "weight": 500 },
        "body-lg": { "size": "16px", "lineHeight": "26px", "weight": 400 },
        "heading-sm": { "size": "16px", "lineHeight": "22px", "weight": 700, "fontFamily": "display" },
        "heading": { "size": "20px", "lineHeight": "28px", "weight": 700, "fontFamily": "display" },
        "heading-lg": { "size": "28px", "lineHeight": "36px", "weight": 700, "fontFamily": "display" },
        "display": { "size": "36px", "lineHeight": "44px", "weight": 800, "fontFamily": "display" }
      }
    },
    "spacing": {
      "0": "0px",
      "0.5": "2px",
      "1": "4px",
      "1.5": "6px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "5": "20px",
      "6": "24px",
      "8": "32px",
      "10": "40px",
      "12": "48px",
      "16": "64px"
    },
    "borderRadius": {
      "sm": "6px",
      "DEFAULT": "8px",
      "md": "10px",
      "lg": "12px",
      "xl": "16px",
      "2xl": "20px",
      "full": "9999px"
    },
    "shadows": {
      "sm": "0 1px 2px rgba(0,0,0,0.3)",
      "DEFAULT": "0 1px 3px rgba(0,0,0,0.4), 0 4px 12px -4px rgba(0,0,0,0.35)",
      "md": "0 2px 8px rgba(0,0,0,0.4), 0 8px 24px -8px rgba(0,0,0,0.4)",
      "lg": "0 4px 16px rgba(0,0,0,0.45), 0 16px 48px -12px rgba(0,0,0,0.5)",
      "glow": "0 0 20px rgba(99,102,241,0.15), 0 0 60px rgba(99,102,241,0.05)",
      "glass": "0 1px 1px rgba(0,0,0,0.3), 0 4px 16px -4px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.03)"
    },
    "animation": {
      "duration": {
        "instant": "50ms",
        "fast": "150ms",
        "normal": "250ms",
        "slow": "400ms",
        "spring": "500ms"
      },
      "easing": {
        "default": "cubic-bezier(0.4, 0, 0.2, 1)",
        "spring": "cubic-bezier(0.16, 1, 0.3, 1)",
        "bounce": "cubic-bezier(0.34, 1.56, 0.64, 1)",
        "ease-in": "cubic-bezier(0.4, 0, 1, 1)",
        "ease-out": "cubic-bezier(0, 0, 0.2, 1)"
      }
    },
    "zIndex": {
      "dropdown": 50,
      "sticky": 100,
      "modal": 200,
      "toast": 300,
      "tooltip": 400
    }
  },
  "components": [
    { "name": "Button", "variants": ["primary", "ghost", "danger", "icon-only"], "sizes": ["sm", "md", "lg"], "states": ["default", "hover", "active", "disabled", "loading"] },
    { "name": "Card", "variants": ["glass", "solid", "interactive"], "features": ["header slot", "footer slot", "hover elevation"] },
    { "name": "Input", "variants": ["text", "password", "search", "email"], "features": ["label", "error", "hint", "icon-left", "icon-right"] },
    { "name": "Select", "variants": ["native", "custom"], "features": ["label", "error", "custom arrow"] },
    { "name": "Textarea", "features": ["auto-resize", "char count", "label", "error"] },
    { "name": "Modal", "variants": ["dialog", "bottom-sheet", "drawer"], "features": ["focus trap", "backdrop blur", "scale animation", "Escape close"] },
    { "name": "Badge", "variants": ["status", "priority", "count", "dot"], "sizes": ["sm", "md"] },
    { "name": "Toast", "variants": ["success", "error", "warning", "info"], "features": ["dismiss", "undo action", "progress bar", "stacking"] },
    { "name": "Tooltip", "features": ["positioning", "delay", "arrow", "keyboard accessible"] },
    { "name": "Avatar", "variants": ["initials", "image"], "features": ["sizes", "status dot", "AvatarGroup stacking"] },
    { "name": "Progress", "variants": ["linear-bar", "ring"], "features": ["animated value transition", "gradient", "glow"] },
    { "name": "EmptyState", "features": ["icon/illustration", "title", "description", "action button"] },
    { "name": "Skeleton", "variants": ["text", "circle", "card", "avatar", "button"], "features": ["shimmer animation"] },
    { "name": "Dropdown", "features": ["trigger", "portal menu", "items with icons", "keyboard nav"] },
    { "name": "Tabs", "features": ["horizontal", "animated indicator", "controlled/uncontrolled"] },
    { "name": "Toggle", "features": ["switch animation", "label", "sizes"] },
    { "name": "IconButton", "features": ["tooltip", "sizes", "variants matching Button"] }
  ],
  "animationPhilosophy": {
    "principles": [
      "Purposeful: every animation serves a UX goal (feedback, orientation, delight)",
      "Performant: transform + opacity only, no layout triggers, 60fps always",
      "Respectful: honor prefers-reduced-motion, provide instant alternatives",
      "Consistent: same easing/duration for same type of motion across the app"
    ],
    "catalog": [
      "fadeIn: page sections, modals backdrop (250ms ease-out)",
      "scaleIn: modals, dropdowns (250ms spring)",
      "slideUp: bottom sheets, toasts (300ms spring)",
      "slideRight: toast enter (300ms spring)",
      "stagger: list items on expand (50ms delay per item, 200ms fadeIn)",
      "completion: checkmark draw + subtle confetti burst (400ms)",
      "shimmer: skeleton loading (3s infinite ease-in-out)",
      "pulse: status indicators, waiting states (2s infinite)",
      "pressScale: button press (100ms scale 0.97)",
      "hoverLift: cards, interactive elements (200ms translateY -1px)"
    ]
  },
  "mobileStrategy": {
    "breakpoints": { "sm": "640px", "md": "768px", "lg": "1024px", "xl": "1280px", "2xl": "1536px" },
    "patterns": [
      "Bottom sheet modals with drag-to-dismiss handle",
      "Swipe gestures on task rows (right=complete, left=delete)",
      "Floating Action Button with radial expand menu",
      "Bottom tab navigation: Hafta, Takım, AI, Notlar",
      "Sticky compact header on scroll with backdrop blur",
      "Safe area insets for notch/island devices",
      "Touch targets minimum 44x44px on all interactive elements"
    ]
  },
  "accessibilityStandards": {
    "level": "WCAG 2.1 AA",
    "requirements": [
      "Color contrast: 4.5:1 normal text, 3:1 large text",
      "Focus visible: 2px solid accent ring on all focusable elements",
      "Focus trapping in modals, drawers, panels",
      "Keyboard navigation: Tab, Enter, Space, Escape, Arrow keys",
      "ARIA labels on all interactive elements",
      "Live regions for dynamic content",
      "Heading hierarchy h1-h6 without gaps",
      "Skip-to-content link",
      "Landmark roles: main, banner, nav, complementary",
      "Keyboard shortcuts overlay on ? key"
    ]
  }
}
